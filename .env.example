# RHDP Lab Tools configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OCP cluster API URL (required)
OCP_API=https://api.your-cluster.example.com:6443

# OCP bearer token (required for login)
OCP_TOKEN=sha256~your-token-here

# SSH credentials for KubeVirt VMs (used by ssh_* functions)
RHDP_SSH_USER=rhel
RHDP_SSH_PASS=your-ssh-password

# Local port for SSH tunnel (optional, default: 2222)
# RHDP_SSH_PORT=2222
